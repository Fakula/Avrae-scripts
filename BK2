automation:
  - type: custom
    code: |
      # 1. Definieren aller möglichen Skills
      {% set all_skills = [
        "acrobatics", "animal handling", "arcana", "athletics", "deception", 
        "history", "insight", "intimidation", "investigation", "medicine", 
        "nature", "perception", "performance", "persuasion", "religion", 
        "sleight of hand", "stealth", "survival"
      ] %}
      
      # 2. Filtern: Nur Skills behalten, in denen der Charakter KEINE Proficiency/Expertise hat
      {% set available_skills = [] %}
      {% for s in all_skills %}
        {% if not character.skills[s].proficient and not character.skills[s].expertise %}
          {% do available_skills.append(s) %}
        {% endif %}
      {% endfor %}
      
      # 3. Die gefilterte Liste für den nächsten Schritt (Choice) speichern
      {% set ctx = {"available": available_skills} %}
      {{ctx}}

  # 4. Dynamische Auswahl
  - type: choice
    name: Skill
    # Hier ziehen wir die gefilterte Liste aus dem vorherigen Block
    choices: "{{ctx.available}}"

  - type: custom
    code: |
      {% set s = choice.Skill %}
      {% set target_name = "Borrowed Knowledge: " ~ s %}
      
      # Da wir oben filtern, brauchen wir hier keinen Check auf natürliche Proficiency mehr.
      # Wir prüfen nur noch, ob GENAU DIESER Skill schon durch den Zauber aktiv ist.
      {% for item in character.inventory if target_name.lower() in item.name.lower() %}
          {{fail("Borrowed Knowledge ist bereits für " ~ s ~ " aktiv!")}}
      {% endfor %}

      # Cleanup: Alten Zauber-Skill entfernen
      {% set replaced_skill = "" %}
      {% for item in character.inventory if "Borrowed Knowledge:" in item.name %}
          {% set replaced_skill = item.name.split(': ')[1] %}
          {{item.remove()}}
      {% endfor %}
      
      {% set ctx = {"replaced": replaced_skill} %}
      {{ctx}}

  - type: text
    content: |
      ### ✨ Borrowed Knowledge wirkt!
      {% if ctx.replaced %}
      *Der Fokus auf **{{ctx.replaced}}** schwindet...*
      {% endif %}
      **Neuer Skill:** `{{choice.Skill | title}}` (Proficiency für 1 Stunde)

  - type: itemcreate
    name: "Borrowed Knowledge: {{choice.Skill}}"
    item:
      type: wondrous
      rarity: common
      description: "Grants proficiency in {{choice.Skill}} via Borrowed Knowledge."
      effects:
        - name: "Borrowed Knowledge ({{choice.Skill}})"
          duration: 1h
          skill: "{{choice.Skill}} +prof"
          removeitem: true
